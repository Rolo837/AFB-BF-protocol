{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rolo837/AFB-BF-protocol/spec/schemas/deal.v2.json",
  "title": "ExecutionDeal afb.deal.v2",
  "description": "Multi-entry / multi-exit deal. entry, stop_loss, take_profit are root-level lists; each element may carry an optional `percent` (decimal string). Sum of percents per role resolves to 100. The deal-level `direction` (long/short) is the single source of truth for position bias — entry legs no longer carry a per-leg `side`, which would let 'buy' and 'sell' legs coexist in the same deal with no defined semantics (a deal is one position, not a basket of unrelated orders). The broker-facing buy/sell of each leg is derived from `direction` and its role: long entry / short exit -> buy; short entry / long exit -> sell. Reuses order/sizing/target defs from deal.v1.json, but defines its own conditionNode: unlike afb.deal.v1 (price-only), afb.deal.v2 conditions may compare price/quote/indicator/dataset expressions against a constant or (for indicator/dataset) against another expression of the same kind. `crossing`-family ops compare `left` against `right` at both the current and previous sample; for a constant `right` the previous value equals the current one, reducing to the v1 semantics.",
  "type": "object",
  "required": ["schema", "deal_id", "revision", "target", "direction", "entry", "sizing"],
  "properties": {
    "schema": {"const": "afb.deal.v2"},
    "deal_id": {"type": "string", "minLength": 1},
    "revision": {"type": "integer", "minimum": 1},
    "owner": {"type": "object"},
    "target": {"$ref": "deal.v1.json#/$defs/target"},
    "direction": {"enum": ["long", "short"]},
    "entry": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["condition"],
        "properties": {
          "percent": {"$ref": "deal.v1.json#/$defs/decimalString"},
          "condition": {"$ref": "#/$defs/conditionNode"},
          "order": {"$ref": "deal.v1.json#/$defs/order"}
        }
      }
    },
    "stop_loss": {"$ref": "#/$defs/exitList"},
    "take_profit": {"$ref": "#/$defs/exitList"},
    "sizing": {"$ref": "deal.v1.json#/$defs/sizing"},
    "execution_policy": {"$ref": "deal.v1.json#/$defs/executionPolicy"},
    "archive_reason": {"type": "string"}
  },
  "$defs": {
    "rightConst": {
      "type": "object",
      "required": ["const"],
      "properties": {"const": {"$ref": "deal.v1.json#/$defs/decimalString"}}
    },
    "priceExpr": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": {"const": "price"},
        "field": {"const": "last"}
      }
    },
    "quoteExpr": {
      "type": "object",
      "required": ["source", "field"],
      "properties": {
        "source": {"const": "quote"},
        "field": {"enum": ["bid", "ask"]}
      }
    },
    "indicatorExpr": {
      "type": "object",
      "required": ["source", "type"],
      "properties": {
        "source": {"const": "indicator"},
        "type": {"enum": ["wma", "kama", "psar"]},
        "field": {"type": "string"},
        "params": {"type": "object"},
        "id": {"type": "string"}
      }
    },
    "datasetExpr": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": {"const": "dataset"},
        "field": {"type": "string"},
        "dataset_id": {"type": "string"},
        "params": {"type": "object"}
      }
    },
    "conditionNode": {
      "type": "object",
      "required": ["node_type", "op", "left", "right"],
      "properties": {
        "node_type": {"const": "event"},
        "id": {"type": "string"},
        "op": {"enum": ["above", "below", "crosses_above", "crosses_below", "crossing"]}
      },
      "oneOf": [
        {
          "properties": {
            "left": {"oneOf": [{"$ref": "#/$defs/priceExpr"}, {"$ref": "#/$defs/quoteExpr"}]},
            "right": {"$ref": "#/$defs/rightConst"}
          }
        },
        {
          "properties": {
            "left": {"$ref": "#/$defs/indicatorExpr"},
            "right": {"oneOf": [{"$ref": "#/$defs/rightConst"}, {"$ref": "#/$defs/indicatorExpr"}]}
          }
        },
        {
          "properties": {
            "left": {"$ref": "#/$defs/datasetExpr"},
            "right": {"oneOf": [{"$ref": "#/$defs/rightConst"}, {"$ref": "#/$defs/datasetExpr"}]}
          }
        }
      ]
    },
    "exitList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["condition"],
        "properties": {
          "percent": {"$ref": "deal.v1.json#/$defs/decimalString"},
          "condition": {"$ref": "#/$defs/conditionNode"}
        }
      }
    }
  }
}
