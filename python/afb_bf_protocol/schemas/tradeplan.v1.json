{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rolo837/AFB-BF-protocol/spec/schemas/tradeplan.v1.json",
  "title": "TradePlan template afb.tradeplan.v1",
  "description": "AFB-side single-entry / single-exit trade plan template, persisted per-user and compiled by AFB into an afb.deal.v1. This is NOT an AsyncAPI wire message — it never crosses the AFB<->BF channel. `schema` is optional: its absence means afb.tradeplan.v1 (compatibility with frontends older than the tradeplan schema itself).",
  "type": "object",
  "required": ["id", "ticker", "entry_condition"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "ticker": {"type": "string", "minLength": 1},
    "status": {"enum": ["new", "active", "published", "closed", "expired"]},
    "direction": {
      "enum": ["long", "short"]
    },
    "schema": {"const": "afb.tradeplan.v1"},
    "activated_at": {"type": "string"},
    "closed_at": {"type": "string"},
    "entry_condition": {"$ref": "#/$defs/entryCondition"},
    "quantity_value": {"type": ["number", "null"]},
    "quantity_mode": {"enum": ["lots", "margin", "balance_pct", "risk_currency", "risk_factor"]},
    "take_profit": {"oneOf": [{"$ref": "#/$defs/condition"}, {"type": "null"}]},
    "stop_loss": {"oneOf": [{"$ref": "#/$defs/condition"}, {"type": "null"}]},
    "deal_id": {"type": "string"},
    "connector": {
      "type": "string",
      "minLength": 1,
      "description": "AFB bf_id (real connector or virtual) used when publishing this plan. Omitted when user has neither trade nor virtual capability."
    },
    "delivery_at": {
      "type": "string",
      "description": "AFB mail/deals read watermark: notifications with created_at <= delivery_at are treated as read on reconnect."
    },
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  },
  "$defs": {
    "priceCondition": {
      "type": "object",
      "required": ["price_value"],
      "properties": {
        "condition_type": {"const": "price"},
        "price_value": {"type": "number"}
      }
    },
    "marketOrPriceCondition": {
      "type": "object",
      "properties": {
        "condition_type": {"const": "price"},
        "price_value": {"type": ["number", "null"]}
      }
    },
    "primitiveCondition": {
      "type": "object",
      "required": ["condition_type", "primitive_id"],
      "properties": {
        "condition_type": {"const": "primitive"},
        "primitive_id": {"type": "string", "minLength": 1},
        "price_value": {"type": ["number", "null"]}
      }
    },
    "condition": {
      "oneOf": [{"$ref": "#/$defs/priceCondition"}, {"$ref": "#/$defs/primitiveCondition"}]
    },
    "entryCondition": {
      "description": "price_value: null with condition_type price means market entry.",
      "oneOf": [{"$ref": "#/$defs/marketOrPriceCondition"}, {"$ref": "#/$defs/primitiveCondition"}]
    }
  }
}
