{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rolo837/AFB-BF-protocol/spec/schemas/afbws/alarm.channel.v1.json",
  "x-afbws-support-id": "afbws.alarm.channel.v1",
  "title": "alarm channel — schema-first (AFB backend<->AFB frontend only; not part of afb.execution.v1 wire)",
  "description": "Negotiated via auth.support/auth_ok.support (capability id afbws.alarm.channel.v1). Replaces bulk settings/get_alarms+set_alarms and mail/alarms+mail/ack for clients that negotiated this capability; legacy stays available as fallback for clients that did not. See AFB/docs/ENTITY_WS_PROTOCOL.md.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/getRequest" },
    { "$ref": "#/$defs/getResponse" },
    { "$ref": "#/$defs/listRequest" },
    { "$ref": "#/$defs/listResponse" },
    { "$ref": "#/$defs/setRequest" },
    { "$ref": "#/$defs/setResponse" },
    { "$ref": "#/$defs/deleteRequest" },
    { "$ref": "#/$defs/deleteResponse" },
    { "$ref": "#/$defs/errorResponse" },
    { "$ref": "#/$defs/triggeredPush" },
    { "$ref": "#/$defs/ackRequest" },
    { "$ref": "#/$defs/ackResponse" }
  ],
  "$defs": {
    "getRequest": {
      "type": "object",
      "required": ["channel", "schema", "request_id", "id"],
      "additionalProperties": false,
      "properties": {
        "channel": { "const": "alarm" },
        "schema": { "const": "afbws.alarm.get.request.v1" },
        "request_id": { "$ref": "common.v1.json#/$defs/requestId" },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "getResponse": {
      "type": "object",
      "required": ["channel", "schema", "request_id", "item"],
      "additionalProperties": false,
      "properties": {
        "channel": { "const": "alarm" },
        "schema": { "const": "afbws.alarm.get.response.v1" },
        "request_id": { "$ref": "common.v1.json#/$defs/requestId" },
        "item": { "$ref": "../alarm.v1.json" }
      }
    },
    "listRequest": {
      "type": "object",
      "required": ["channel", "schema", "request_id"],
      "additionalProperties": false,
      "properties": {
        "channel": { "const": "alarm" },
        "schema": { "const": "afbws.alarm.list.request.v1" },
        "request_id": { "$ref": "common.v1.json#/$defs/requestId" },
        "ticker": { "type": "string", "minLength": 1 }
      }
    },
    "listResponse": {
      "type": "object",
      "required": ["channel", "schema", "request_id", "items"],
      "additionalProperties": false,
      "properties": {
        "channel": { "const": "alarm" },
        "schema": { "const": "afbws.alarm.list.response.v1" },
        "request_id": { "$ref": "common.v1.json#/$defs/requestId" },
        "items": { "type": "array", "items": { "$ref": "../alarm.v1.json" } }
      }
    },
    "setRequest": {
      "type": "object",
      "required": ["channel", "schema", "request_id", "item"],
      "additionalProperties": false,
      "properties": {
        "channel": { "const": "alarm" },
        "schema": { "const": "afbws.alarm.set.request.v1" },
        "request_id": { "$ref": "common.v1.json#/$defs/requestId" },
        "item": { "$ref": "../alarm.v1.json" }
      }
    },
    "setResponse": {
      "type": "object",
      "required": ["channel", "schema", "request_id", "item"],
      "additionalProperties": false,
      "properties": {
        "channel": { "const": "alarm" },
        "schema": { "const": "afbws.alarm.set.response.v1" },
        "request_id": { "$ref": "common.v1.json#/$defs/requestId" },
        "item": { "$ref": "../alarm.v1.json" }
      }
    },
    "deleteRequest": {
      "type": "object",
      "required": ["channel", "schema", "request_id", "id"],
      "additionalProperties": false,
      "properties": {
        "channel": { "const": "alarm" },
        "schema": { "const": "afbws.alarm.delete.request.v1" },
        "request_id": { "$ref": "common.v1.json#/$defs/requestId" },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "deleteResponse": {
      "type": "object",
      "required": ["channel", "schema", "request_id", "id"],
      "additionalProperties": false,
      "properties": {
        "channel": { "const": "alarm" },
        "schema": { "const": "afbws.alarm.delete.response.v1" },
        "request_id": { "$ref": "common.v1.json#/$defs/requestId" },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "errorResponse": {
      "type": "object",
      "required": ["channel", "schema", "request_id", "code", "message"],
      "additionalProperties": false,
      "properties": {
        "channel": { "const": "alarm" },
        "schema": { "const": "afbws.alarm.error.response.v1" },
        "request_id": { "$ref": "common.v1.json#/$defs/requestId" },
        "code": { "$ref": "common.v1.json#/$defs/errorCode" },
        "message": { "type": "string", "minLength": 1 },
        "details": { "type": "object" }
      }
    },
    "triggerEvent": {
      "type": "object",
      "required": ["schema", "alarm_id", "triggered_at", "alarm"],
      "additionalProperties": false,
      "properties": {
        "schema": { "const": "afb.alarm.trigger.v1" },
        "alarm_id": { "type": "string", "minLength": 1 },
        "triggered_at": { "type": "string", "minLength": 1 },
        "alarm": { "$ref": "../alarm.v1.json" },
        "current_price": { "type": "number" }
      }
    },
    "triggeredPush": {
      "type": "object",
      "title": "alarm/triggered push (server-initiated, no request_id)",
      "required": ["channel", "schema", "events"],
      "additionalProperties": false,
      "properties": {
        "channel": { "const": "alarm" },
        "schema": { "const": "afbws.alarm.triggered.push.v1" },
        "events": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/triggerEvent" } }
      }
    },
    "ackEvent": {
      "type": "object",
      "required": ["schema", "alarm_id", "triggered_at"],
      "additionalProperties": false,
      "properties": {
        "schema": { "const": "afb.alarm.trigger_ack.v1" },
        "alarm_id": { "type": "string", "minLength": 1 },
        "triggered_at": { "type": "string", "minLength": 1 }
      }
    },
    "ackRequest": {
      "type": "object",
      "required": ["channel", "schema", "request_id", "events"],
      "additionalProperties": false,
      "properties": {
        "channel": { "const": "alarm" },
        "schema": { "const": "afbws.alarm.ack.request.v1" },
        "request_id": { "$ref": "common.v1.json#/$defs/requestId" },
        "events": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ackEvent" } }
      }
    },
    "ackResultItem": {
      "type": "object",
      "required": ["schema", "alarm_id", "triggered_at", "status"],
      "additionalProperties": false,
      "properties": {
        "schema": { "const": "afbws.alarm.ack_result.v1" },
        "alarm_id": { "type": "string", "minLength": 1 },
        "triggered_at": { "type": "string", "minLength": 1 },
        "status": { "enum": ["ok", "not_found"] }
      }
    },
    "ackResponse": {
      "type": "object",
      "required": ["channel", "schema", "request_id", "results"],
      "additionalProperties": false,
      "properties": {
        "channel": { "const": "alarm" },
        "schema": { "const": "afbws.alarm.ack.response.v1" },
        "request_id": { "$ref": "common.v1.json#/$defs/requestId" },
        "results": { "type": "array", "items": { "$ref": "#/$defs/ackResultItem" } }
      }
    }
  }
}
