{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rolo837/AFB-BF-protocol/spec/schemas/settings/interface.v1.json",
  "title": "settings.interface — UI prefs (AFB-only; not part of afb.execution.v1 wire)",
  "description": "Every property optional (partial-update / overrides-only semantics). offset_right/offset_top/debug_mode are NOT here — canon location is service.v1.json (historical drift: these used to also appear under interface/root, cleaned up by AFB/scripts/migrate_user_settings_canon.sh).",
  "$defs": {
    "chartToolbar": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "favorite_timeframes": { "type": "array", "items": { "type": "string" } },
        "favorite_datasets": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Elements are either `dataset-<preset>` keys or indicator ids."
        },
        "favorite_primitives": {
          "type": "array",
          "items": { "type": "string" },
          "description": "ChartPrimitive kind values (settings/primitive.v1.json#kind)."
        }
      }
    },
    "servicesFilters": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "instruments": {
          "type": "object",
          "additionalProperties": true,
          "properties": { "markets": { "type": "array", "items": { "type": "string" } } }
        },
        "alarms": {
          "type": "object",
          "additionalProperties": true,
          "properties": { "statuses": { "type": "array", "items": { "type": "string" } } }
        },
        "plans": {
          "type": "object",
          "additionalProperties": true,
          "properties": { "statuses": { "type": "array", "items": { "type": "string" } } }
        }
      }
    }
  },
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "snow_mode": { "type": "boolean" },
    "confirm_delete": { "type": "boolean" },
    "smart_alarms": { "type": "boolean" },
    "preset_timeframes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "positions": { "type": "string" },
        "trades": { "type": "string" },
        "hhi": { "type": "string" },
        "orders": { "type": "string" }
      }
    },
    "chart_toolbar": { "$ref": "#/$defs/chartToolbar" },
    "services_filters": { "$ref": "#/$defs/servicesFilters" },
    "trade_plan_default_capital_rub": { "type": "number" }
  }
}
