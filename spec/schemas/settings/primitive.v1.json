{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rolo837/AFB-BF-protocol/spec/schemas/settings/primitive.v1.json",
  "title": "Chart primitive — settings.primitives[secid][] element (AFB-only; not part of afb.execution.v1 wire)",
  "description": "Client-only PrimitiveInstrumentRubMeta (ruler ruble-label metadata, computed from instrument step/lotsize) is NOT part of this schema — never persisted.",
  "$defs": {
    "point": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "time": { "type": "integer", "description": "Unix seconds, as in klines." },
        "price": { "type": "number" }
      }
    }
  },
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": ["line", "line_enter", "line_sl", "line_tp", "note", "zone", "ruler"]
    },
    "start": { "$ref": "#/$defs/point" },
    "stop": {
      "$ref": "#/$defs/point",
      "description": "Second anchor — zone/ruler only; absent for line*/note."
    },
    "text": { "type": "string", "maxLength": 160, "description": "note only." },
    "used_in_tradeplans": { "type": "boolean" }
  }
}
