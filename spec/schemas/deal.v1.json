{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rolo837/AFB-BF-protocol/spec/schemas/deal.v1.json",
  "title": "ExecutionDeal afb.deal.v1",
  "description": "Single-entry / single-exit deal. All prices, steps, sizing values and thresholds are decimal STRINGS. The deal-level `direction` (long/short, same vocabulary as afb.deal.v2) is the single source of truth for position bias.",
  "type": "object",
  "required": ["schema", "deal_id", "revision", "target", "direction", "entry", "sizing"],
  "properties": {
    "schema": {"const": "afb.deal.v1"},
    "deal_id": {"type": "string", "minLength": 1},
    "revision": {"type": "integer", "minimum": 1},
    "owner": {"type": "object", "properties": {"user_id": {"type": "string"}}},
    "target": {"$ref": "#/$defs/target"},
    "direction": {"enum": ["long", "short"]},
    "entry": {"$ref": "#/$defs/entry"},
    "sizing": {"$ref": "#/$defs/sizing"},
    "risk": {
      "type": "object",
      "properties": {
        "take_profit": {"$ref": "#/$defs/exitBlock"},
        "stop_loss": {"$ref": "#/$defs/exitBlock"}
      }
    },
    "execution_policy": {"$ref": "#/$defs/executionPolicy"},
    "archive_reason": {"type": "string"}
  },
  "$defs": {
    "decimalString": {"type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?$"},
    "instrument": {
      "type": "object",
      "required": ["exchange", "board", "ticker"],
      "properties": {
        "exchange": {"type": "string"},
        "board": {"type": "string"},
        "ticker": {"type": "string"},
        "market": {"enum": ["stock", "futures", "currency"]},
        "price_step": {"$ref": "#/$defs/decimalString"},
        "step_price": {"$ref": "#/$defs/decimalString"}
      }
    },
    "target": {
      "type": "object",
      "required": ["bf_id", "broker", "instrument"],
      "properties": {
        "bf_id": {"type": "string"},
        "broker": {"type": "string"},
        "instrument": {"$ref": "#/$defs/instrument"},
        "binding": {"type": "object", "description": "broker-native locator added by BF after publish"}
      }
    },
    "conditionNode": {
      "type": "object",
      "required": ["node_type", "op", "left", "right"],
      "properties": {
        "node_type": {"const": "event"},
        "id": {"type": "string"},
        "op": {"enum": ["above", "below", "crosses_above", "crosses_below", "crossing"]},
        "left": {
          "type": "object",
          "required": ["source"],
          "description": "afb.deal.v1 conditions only compare against the last traded price. quote/indicator/dataset sources are afb.deal.v2-only.",
          "properties": {
            "source": {"const": "price"},
            "field": {"const": "last"}
          }
        },
        "right": {
          "type": "object",
          "required": ["const"],
          "properties": {"const": {"$ref": "#/$defs/decimalString"}}
        }
      }
    },
    "entry": {
      "type": "object",
      "required": ["condition"],
      "properties": {
        "condition": {"$ref": "#/$defs/conditionNode"}
      }
    },
    "exitBlock": {
      "type": "object",
      "properties": {"condition": {"$ref": "#/$defs/conditionNode"}}
    },
    "sizing": {
      "type": "object",
      "required": ["mode", "value"],
      "properties": {
        "mode": {"enum": ["lots", "margin", "risk_currency", "risk_factor", "balance_pct"]},
        "value": {"$ref": "#/$defs/decimalString"}
      }
    },
    "executionPolicy": {
      "type": "object",
      "properties": {
        "on_afb_disconnect": {"type": "string"},
        "max_spread_steps": {"type": "integer"},
        "margin_trading": {"type": "boolean"},
        "execution_mode": {
          "enum": ["client", "hybrid", "server"],
          "description": "How exit protection is executed. Absent means `client` (condition engine only, current behaviour). `hybrid` additionally places a server-side SLTP backstop order once a position opens. `server` is reserved — not yet implemented by any BF, always rejected at publish. See RESILIENCE.md, Фаза 3/5."
        },
        "backstop": {
          "type": "object",
          "description": "Per-deal overrides for the hybrid-mode server-side backstop order; unset fields fall back to the executing BF's own config defaults. Meaningful only when execution_mode is `hybrid`.",
          "properties": {
            "offset_steps": {"type": "integer", "minimum": 0},
            "stop_price": {"$ref": "#/$defs/decimalString"},
            "max_loss_steps": {"type": "integer", "minimum": 1},
            "take_profit": {
              "type": "boolean",
              "description": "Reserved for a future server-side take-profit leg (OCO). Always rejected as true for now — the backstop is protection-only in this phase."
            }
          }
        }
      }
    }
  }
}
