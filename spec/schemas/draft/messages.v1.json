{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rolo837/AFB-BF-protocol/spec/schemas/draft/messages.v1.json",
  "title": "`settings` WS channel messages (AFB-only; not part of afb.execution.v1 wire)",
  "description": "Pure $defs bag, no meaningful root shape (mirrors condition.v1.json's redirect-only-root convention) — each $def is one request or response/push body (channel wrapper added at runtime by send_channel, not part of these schemas). `default`+`settings` also arrive unsolicited right after auth (see AFB/backend/api/websocket_handler.py). `set_default` is manager-only. Any success response can be intersected with `rejectedEnvelope` to get its rejected form — see AFB/backend/api/ws_response.py (rejected_msg): rejections reuse the success `type` and carry the authoritative current `data`, plus `rejected:true` and `message`.",
  "$defs": {
    "rejectedEnvelope": {
      "type": "object",
      "required": ["rejected", "message"],
      "additionalProperties": true,
      "properties": {
        "rejected": { "const": true },
        "message": { "type": "string" }
      }
    },

    "getDefaultRequest": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "type": { "const": "get_default" } }
    },
    "defaultPayload": {
      "type": "object",
      "description": "Platform defaults (config/_default_.yaml); dashboard/favorites fall back to code defaults if absent from the file.",
      "additionalProperties": true,
      "properties": {
        "interface": { "$ref": "interface.v1.json" },
        "service": { "$ref": "service.v1.json" },
        "dashboard": { "$ref": "dashboard.v1.json" },
        "dataset": { "$ref": "dataset.v1.json" },
        "indicators": { "type": "array", "items": { "$ref": "indicator.v1.json" } },
        "favorites": { "type": "array", "items": { "type": "string" } }
      }
    },
    "defaultPush": {
      "type": "object",
      "required": ["type", "data"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "default" },
        "data": { "$ref": "#/$defs/defaultPayload" }
      }
    },

    "getRequest": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "type": { "const": "get" } }
    },
    "setRequest": {
      "type": "object",
      "required": ["type", "data"],
      "additionalProperties": true,
      "description": "`role` in data is ignored. `tradeplans`/`primitives` in data are ignored (set_plans/set_primitives own those). `name`/`limits` are stripped server-side even if present.",
      "properties": {
        "type": { "const": "set" },
        "data": { "$ref": "user_file.v1.json" }
      }
    },
    "settingsPush": {
      "type": "object",
      "required": ["type", "data"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "settings" },
        "data": { "$ref": "settings_payload.v1.json" }
      }
    },

    "setDefaultRequest": {
      "type": "object",
      "required": ["type", "data"],
      "additionalProperties": true,
      "description": "Manager-only. data.dataset is required by the backend (\"Поле 'data.dataset' обязательно\").",
      "properties": {
        "type": { "const": "set_default" },
        "data": {
          "type": "object",
          "required": ["dataset"],
          "additionalProperties": true,
          "properties": {
            "dataset": { "$ref": "dataset.v1.json" },
            "interface": { "$ref": "interface.v1.json" },
            "indicators": { "type": "array", "items": { "$ref": "indicator.v1.json" } },
            "service": { "$ref": "service.v1.json" },
            "favorites": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },

    "getAlarmsRequest": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "type": { "const": "get_alarms" } }
    },
    "setAlarmsRequest": {
      "type": "object",
      "required": ["type", "data"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "set_alarms" },
        "data": { "type": "array", "items": { "$ref": "../alarm.v1.json" } }
      }
    },
    "alarmsPush": {
      "type": "object",
      "required": ["type", "data"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "alarms" },
        "data": { "type": "array", "items": { "$ref": "../alarm.v1.json" } }
      }
    },
    "updateAlarmRequest": {
      "type": "object",
      "required": ["type", "alarm_id", "data"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "update_alarm" },
        "alarm_id": { "type": "string" },
        "data": { "$ref": "../alarm.v1.json" }
      }
    },
    "alarmUpdatedPush": {
      "type": "object",
      "required": ["type", "data"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "alarm_updated" },
        "data": { "$ref": "../alarm.v1.json" }
      }
    },

    "getPlansRequest": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "type": { "const": "get_plans" } }
    },
    "tradeplanListItem": {
      "oneOf": [{ "$ref": "../tradeplan.v1.json" }, { "$ref": "../tradeplan.v2.json" }]
    },
    "setPlansRequest": {
      "type": "object",
      "required": ["type", "data"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "set_plans" },
        "data": { "type": "array", "items": { "$ref": "#/$defs/tradeplanListItem" } }
      }
    },
    "plansPush": {
      "type": "object",
      "required": ["type", "data"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "plans" },
        "data": { "type": "array", "items": { "$ref": "#/$defs/tradeplanListItem" } }
      }
    },
    "updatePlanRequest": {
      "type": "object",
      "required": ["type", "plan_id", "data"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "update_plan" },
        "plan_id": { "type": "string" },
        "data": { "$ref": "#/$defs/tradeplanListItem" }
      }
    },
    "planAmendResult": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "deal_id": { "type": "string" },
        "accepted": { "type": "boolean" },
        "message": { "type": "string" }
      }
    },
    "planUpdatedPush": {
      "type": "object",
      "required": ["type", "data"],
      "additionalProperties": true,
      "description": "`amend` present when the plan is linked to a live deal (status in published/active/paused/orphaned) — backend translates the edit to deal.amend on BF.",
      "properties": {
        "type": { "const": "plan_updated" },
        "data": { "$ref": "#/$defs/tradeplanListItem" },
        "amend": { "type": "array", "items": { "$ref": "#/$defs/planAmendResult" } }
      }
    },

    "getFavoritesRequest": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "type": { "const": "get_favorites" } }
    },
    "setFavoritesRequest": {
      "type": "object",
      "required": ["type", "tickers"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "set_favorites" },
        "tickers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "favoritesPush": {
      "type": "object",
      "required": ["type", "data"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "favorites" },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": { "$ref": "security_instrument.v1.json" },
            "description": "Single-key map {<secid>: SecurityInstrument}."
          }
        }
      }
    },

    "getPrimitivesRequest": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "type": { "const": "get_primitives" } }
    },
    "primitivesBySecid": {
      "type": "object",
      "additionalProperties": { "type": "array", "items": { "$ref": "primitive.v1.json" } }
    },
    "setPrimitivesRequest": {
      "type": "object",
      "required": ["type", "data"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "set_primitives" },
        "data": { "$ref": "#/$defs/primitivesBySecid" }
      }
    },
    "primitivesPush": {
      "type": "object",
      "required": ["type", "data"],
      "additionalProperties": true,
      "description": "`warning` present when a rollback happened during deal-amend reconciliation — data stays authoritative either way.",
      "properties": {
        "type": { "const": "primitives" },
        "data": { "$ref": "#/$defs/primitivesBySecid" },
        "warning": { "type": "string" }
      }
    },

    "errorPush": {
      "type": "object",
      "required": ["type", "message"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "error" },
        "message": { "type": "string" }
      }
    }
  },
  "type": "object",
  "$ref": "#/$defs/rejectedEnvelope"
}
