{
  "name": "afb-bf-protocol",
  "version": "2.0.8",
  "private": false,
  "type": "module",
  "description": "Shared wire protocol (afb.execution.v1) for AFB OMS and BF executor: generated TypeScript taxonomy and models",
  "exports": {
    ".": "./ts/src/index.ts",
    "./taxonomy": "./ts/src/taxonomy.ts",
    "./models": "./ts/src/models.ts",
    "./capabilities": "./ts/src/capabilities.ts"
  },
  "files": [
    "ts/src",
    "spec/schemas",
    "README.md"
  ],
  "scripts": {
    "generate:models": "node ts/tools/generate-models.mjs",
    "typecheck": "tsc --noEmit -p ts/tsconfig.json"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^11.7.0",
    "json-schema-to-typescript": "^15.0.0",
    "typescript": "^5.5.0"
  }
}
